# AnyRouter 账号配置（Cookie 模式）
ANYROUTER_ACCOUNTS=[{"cookies":{"session":"你的session值"},"api_user":"你的api_user值"}]

# Wucur 账号配置（用户名密码登录后复用 session cookie）
# ANYROUTER_ACCOUNTS=[{"name":"wucur","provider":"wucur","username":"你的邮箱","password":"你的密码"}]

# 如使用内置 wucur 配置，通常无需单独设置 PROVIDERS
# PROVIDERS={"wucur":{"domain":"http://wucur.com:6543","login_path":"/login","login_api_path":"/api/user/login","sign_in_path":"/api/user/checkin","user_info_path":"/api/user/self","auth_mode":"password_session","api_user_key":"new-api-user"}}

# 可选：通知配置
# DINGDING_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# EMAIL_USER=your_email@example.com
# EMAIL_PASS=your_password
# EMAIL_TO=recipient@example.com
# EMAIL_SENDER=
# PUSHPLUS_TOKEN=your_pushplus_token
# SERVERPUSHKEY=your_server_pushkey
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# WEIXIN_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# GOTIFY_URL=https://your-gotify-server/message
# GOTIFY_TOKEN=your_gotify_token
# GOTIFY_PRIORITY=9
