<div class="overflow-x-auto bg-base-100 rounded-box shadow">
<table class="table table-sm">
  <thead><tr>
    <th><input type="checkbox" class="checkbox checkbox-xs" onchange="toggleAll(this)"/></th>
    <th>用户名</th><th>密码</th><th>余额</th><th>签到时间</th>
    <th><select class="select select-xs select-ghost" name="status" hx-get="/api/accounts/table" hx-target="#tbody-wucur" hx-swap="innerHTML" hx-include="this"><option value="">状态</option><option value="active">✅ 正常</option><option value="failed">❌ 失败</option></select></th>
    <th>操作</th>
  </tr></thead>
  <tbody id="tbody-wucur">
    {{#accounts}}
    <tr>
      <td><input type="checkbox" class="checkbox checkbox-xs row-check" value="{{username}}"/></td>
      <td class="font-mono">{{username}}</td>
      <td class="font-mono text-xs">
        <span class="inline-flex items-center gap-1">
          <span class="pwd-mask" data-p="{{password}}">••••••</span>
          <button type="button" class="btn btn-ghost btn-xs px-1" onclick="togglePwd(this)" title="显示/隐藏">👁</button>
          <button type="button" class="btn btn-ghost btn-xs px-1" onclick="copyPwd(this)" title="复制">📋</button>
        </span>
      </td>
      <td>{{displayBalance}}</td>
      <td>{{displayTime}}</td>
      <td>{{{statusBadge}}}</td>
      <td class="flex gap-1">
        <button type="button" class="btn btn-xs btn-ghost" hx-get="/api/account/{{username}}" hx-target="#detail-body" hx-swap="innerHTML" onclick="document.getElementById('account-detail').showModal()">详情</button>
        <button type="button" class="btn btn-xs btn-primary" hx-post="/api/trigger" hx-vals='{"action":"checkin","target":"{{username}}"}' hx-swap="none">签到</button>
      </td>
    </tr>
    {{/accounts}}
    {{^accounts}}
    <tr><td colspan="7" class="text-center py-8 text-base-content/50">暂无账号</td></tr>
    {{/accounts}}
  </tbody>
</table>
</div>
<div class="flex justify-center mt-4 gap-1" id="tbody-wucur-pagination"></div>
